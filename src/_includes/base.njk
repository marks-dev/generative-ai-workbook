<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <link rel="icon" href="{{ '/favicon.ico' | url }}" sizes="any">
  <link rel="apple-touch-icon" href="{{ '/apple-touch-icon.png' | url }}">
  <meta name="msapplication-TileImage" content="{{ '/ms-tile.png' | url }}">
  <link rel="stylesheet" href="{{ '/assets/css/site.css' | url }}">
</head>
<body>
  <header class="site-header">
    <div class="site-header__global">
      <a class="site-header__logo" href="{{ '/' | url }}">
        <img src="{{ '/assets/images/logo.svg' | url }}" alt="Generative AI Workbook Logo" class="site-header__logo-img">
      </a>
      <nav class="site-header__nav" aria-label="グローバルナビゲーション">
        <a class="site-header__nav-link" href="{{ '/about/' | url }}">このサイトについて</a>
        <a class="site-header__nav-link" href="{{ '/glossary/' | url }}">用語集</a>
        <button class="site-header__nav-button" type="button" data-learning-progress-open>
          学習状況管理
        </button>
      </nav>
    </div>

    <div class="site-header__context">
      {% if pageType == "top" %}
        <p class="site-header__description">生成AIを体系的に学ぶための自習用ワークブックです。</p>
      {% endif %}

      {% if breadcrumbs %}
        <nav class="breadcrumb" aria-label="パンくずリスト">
          <ol class="breadcrumb__list">
            {% for item in breadcrumbs %}
              <li class="breadcrumb__item">
                {% if item.url and not loop.last %}
                  <a class="breadcrumb__link" href="{{ item.url | url }}">{{ item.label }}</a>
                {% else %}
                  <span class="breadcrumb__current" aria-current="page">{{ item.label }}</span>
                {% endif %}
              </li>
            {% endfor %}
          </ol>
        </nav>
      {% endif %}



      {% if pageType == "content" and completionId %}
        <div class="completion-tooltip-wrapper">
          <button class="completion-button" type="button" data-completion-id="{{ completionId }}" data-completion-title="{{ title }}">
            完了にする
          </button>
          <div class="completion-tooltip" role="tooltip" aria-hidden="true" data-completion-tooltip>
            読み終わったら完了を押しましょう。
          </div>
        </div>
      {% endif %}
    </div>
  </header>

  <div class="learning-progress-panel" hidden data-learning-progress-panel>
    <div class="learning-progress-panel__backdrop" data-learning-progress-close></div>
    <section class="learning-progress-panel__dialog" role="dialog" aria-modal="true" aria-labelledby="learning-progress-title">
      <div class="learning-progress-panel__header">
        <div>
          <p class="learning-progress-panel__eyebrow">LocalStorage</p>
          <h2 id="learning-progress-title">学習状況管理</h2>
        </div>
        <button class="learning-progress-panel__close" type="button" data-learning-progress-close aria-label="学習状況管理を閉じる">閉じる</button>
      </div>

      <p class="learning-progress-panel__summary" data-learning-progress-summary>
        完了済みの教材はまだありません。
      </p>

      <ul class="learning-progress-panel__list" data-learning-progress-list></ul>

      <div class="learning-progress-panel__actions" aria-label="学習状況データ操作">
        <button class="learning-progress-panel__action" type="button" data-learning-progress-export>
          JSONエクスポート
        </button>
        <label class="learning-progress-panel__action learning-progress-panel__action--file">
          JSONインポート
          <input type="file" accept="application/json,.json" data-learning-progress-import>
        </label>
        <button class="learning-progress-panel__action learning-progress-panel__action--danger" type="button" data-learning-progress-reset>
          全状況をリセット
        </button>
      </div>

      <p class="learning-progress-panel__message" data-learning-progress-message aria-live="polite"></p>
    </section>
  </div>

  <main class="site-main{% if pageType %} site-main--{{ pageType }}{% endif %}">
    {{ content | safe }}
  </main>
  <script src="{{ '/assets/js/learning-progress.js' | url }}"></script>
</body>
</html>
