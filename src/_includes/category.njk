---
layout: base.njk
---

<h1 class="visually-hidden">{{ title }}</h1>

{% if learningCards %}
  <section class="learning-card-list" aria-label="教材一覧">
    {% for group in learningCards %}
      <section class="learning-card-group" aria-labelledby="learning-card-group-{{ loop.index }}">
        <h2 id="learning-card-group-{{ loop.index }}" class="learning-card-group__title">{{ group.group }}</h2>

        <ul class="learning-card-group__list">
          {% for item in group.items %}
            <li class="learning-card" 
                {% if item.completionId %}data-card-completion-id="{{ item.completionId }}"{% endif %} 
                {% if item.completionIds %}data-card-completion-ids="{{ item.completionIds | join(',') }}"{% endif %}>
              <a class="learning-card__link" href="{{ item.url | url }}">
                <span class="learning-card__icon" aria-hidden="true">{{ item.icon or "📘" }}</span>
                <span class="learning-card__body">
                  <span class="learning-card__title">{{ item.title }}</span>
                  <span class="learning-card__description">{{ item.description }}</span>
                </span>
                <span class="learning-card__status" aria-label="学習状況">
                  <span class="learning-card__status-badge" 
                        {% if item.completionId %}data-completion-check-id="{{ item.completionId }}"{% endif %} 
                        {% if item.completionIds %}data-completion-check-ids="{{ item.completionIds | join(',') }}"{% endif %}>
                  </span>
                </span>
              </a>
            </li>
          {% endfor %}
        </ul>
      </section>
    {% endfor %}
  </section>
{% endif %}
