---
layout: base.njk
---

<div class="content-layout">
  {% if sidebar %}
    <aside class="content-sidebar" aria-label="カテゴリ内教材">
      <details class="content-sidebar__details">
        <summary class="content-sidebar__summary" title="教材一覧を開く" aria-label="教材一覧を開く">
          <span class="content-sidebar__summary-icon" aria-hidden="true">📖</span>
        </summary>

        {% if sidebar.items %}
          <div class="content-sidebar__list-container">
            {% if sidebar.title %}
              <div class="content-sidebar__list-header">
                <span class="content-sidebar__list-title">{{ sidebar.title }}</span>
              </div>
            {% endif %}
            <ol class="content-sidebar__list">
              {% for item in sidebar.items %}
                <li class="content-sidebar__item">
                  {% if item.url == page.url %}
                    <span class="content-sidebar__current" aria-current="page">
                      <span class="content-sidebar__current-icon" aria-hidden="true">👉</span>{{ item.title }}
                    </span>
                  {% else %}
                    <a class="content-sidebar__link" href="{{ item.url | url }}">{{ item.title }}</a>
                  {% endif %}
                  <span class="content-sidebar__status"{% if item.completionId %} data-completion-status="{{ item.completionId }}"{% endif %}></span>
                </li>
              {% endfor %}
            </ol>
          </div>
        {% endif %}
      </details>
    </aside>
  {% endif %}

  <article class="content-article">
    <header class="content-article__header">
      <h1>{{ title }}</h1>
      {% if description %}
        <p class="content-article__description">{{ description }}</p>
      {% endif %}
    </header>

    {{ content | safe }}


  </article>
</div>
