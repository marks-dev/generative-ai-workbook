---
layout: base.njk
---

<div class="content-layout">
  {% if sidebar %}
    <aside class="content-sidebar" aria-label="カテゴリ内教材">
      <details class="content-sidebar__details" open>
        <summary class="content-sidebar__summary">
          {% if sidebar.title %}
            <span class="content-sidebar__title">{{ sidebar.title }}</span>
          {% endif %}
          <span class="content-sidebar__toggle-icon" aria-hidden="true">▾</span>
        </summary>

        {% if sidebar.items %}
          <ol class="content-sidebar__list">
            {% for item in sidebar.items %}
              <li class="content-sidebar__item">
                {% if item.url == page.url %}
                  <span class="content-sidebar__current" aria-current="page">{{ item.title }}</span>
                {% else %}
                  <a class="content-sidebar__link" href="{{ item.url | url }}">{{ item.title }}</a>
                {% endif %}
                <span class="content-sidebar__status"{% if item.completionId %} data-completion-status="{{ item.completionId }}"{% endif %}>{{ item.status or "未実施" }}</span>
              </li>
            {% endfor %}
          </ol>
        {% endif %}
      </details>
    </aside>
  {% endif %}

  <article class="content-article">
    <header class="content-article__header">
      <h1>{{ title }}</h1>
      {% if description %}
        <p class="content-article__description">{{ description }}</p>
      {% endif %}
    </header>

    {{ content | safe }}


  </article>
</div>
